# Dependencies
node_modules/
dist/

# WASM files (download via script, don't commit)
# These are large (~5MB total) and can be downloaded from CDN
public/duckdb-wasm/*.wasm
public/duckdb-wasm/*.js

# Keep the directory structure but not the files
!public/duckdb-wasm/.gitkeep

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.production

# Build
dist-ssr
*.local
